{
  "name": "@siderite/linqer-ts",
  "version": "3.0.0",
  "description": "LInQer for Typescript",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Siderite/LInQer-ts.git"
  },
  "bugs": {
    "url": "https://github.com/Siderite/LInQer-ts/issues"
  },
  "homepage": "https://github.com/Siderite/LInQer-ts#readme",
  "license": "MIT",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "vite build --config vite.esm.config.ts && vite build --config vite.umd.config.ts",
    "test": "ava",
    "test:unit": "ava",
    "test:watch": "ava --watch",
    "cov": "c8 ava",
    "cov:html": "c8 report --reporter=html",
    "cov:check": "c8 check-coverage --lines 100 --functions 100 --branches 100",
    "doc": "npm run doc:html && npx open-cli docs/index.html",
    "doc:html": "typedoc src --exclude **/*.spec.ts --out docs",
    "doc:json": "typedoc src --exclude **/*.spec.ts --json docs/typedoc.json",
    "doc:publish": "gh-pages -d docs -m \"[ci skip] Updates\""
  },
  "devDependencies": {
    "ava": "^8.0.1",
    "c8": "^11.0.0",
    "gh-pages": "^6.3.0",
    "tsx": "^4.22.4",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-dts": "^5.0.2"
  }
}
